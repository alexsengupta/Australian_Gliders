# ── Data: rebuilt by the pipeline, hosted on Nectar, not in Git ──────────────
anfog_data/            # raw NetCDF (~30 GiB)
anfog_data_viz/        # cleaned visualisation subsets
plotdata/              # per-deployment plot data
deployments.js         # map index (regenerated by extract_deployments.py)

# Large NetCDF anywhere — keep only the small climatology source file
*.nc
!from Amandine/glider_mean_profile_TEMP_NSW.nc

# ── Glider photos: add locally, licensing kept out of Git ────────────────────
assets/*.jpg
assets/*.jpeg
assets/*.png

# ── Pipeline scratch / logs ──────────────────────────────────────────────────
*.log
Forster_downloads*/
Forster_comparison_plots/
List_glider_mission_*.txt

# ── Python / notebooks / OS ──────────────────────────────────────────────────
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
~$*        # Word/Office lock files

# ── Node (only used to build the Word briefing) ──────────────────────────────
node_modules/
package-lock.json
package.json
